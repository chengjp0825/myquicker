<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ===== 主题画刷（非 JSON 配置的颜色，集中管理） ===== -->
    <SolidColorBrush x:Key="AccentBrush"           Color="#0066CC" />
    <SolidColorBrush x:Key="AccentHoverBrush"      Color="#0055AA" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F7F7F7" />
    <SolidColorBrush x:Key="DividerBrush"           Color="#EAEAEA" />
    <SolidColorBrush x:Key="GridLinesBrush"         Color="#EFEFEF" />
    <SolidColorBrush x:Key="AlternatingRowBrush"    Color="#FAFAFA" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush"  Color="#F7F7F7" />
    <SolidColorBrush x:Key="HeaderForegroundBrush"  Color="#333333" />
    <SolidColorBrush x:Key="NavHoverBrush"          Color="#EBEBEB" />

    <!-- ===== 尺寸 / 间距 / 圆角（纯布局，非 JSON） ===== -->
    <Thickness    x:Key="MenuPadding">12</Thickness>
    <Thickness    x:Key="MenuButtonPadding">14,8</Thickness>
    <Thickness    x:Key="ActionButtonMargin">0,4</Thickness>
    <CornerRadius x:Key="MenuButtonCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ActionButtonCornerRadius">6</CornerRadius>
    <sys:Double   x:Key="MenuButtonFontSize">15</sys:Double>
    <sys:Double   x:Key="ActionButtonMinWidth">180</sys:Double>
    <sys:Double   x:Key="SettingsButtonSize">30</sys:Double>
    <GridLength   x:Key="SidebarWidth">160</GridLength>

    <!-- ===== 公共样式 ===== -->

    <!-- 唤醒菜单动作按钮。背景色走 DynamicResource，由 MainWindow code-behind 从 JSON 注入 -->
    <Style x:Key="MenuButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource MenuButtonBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="{StaticResource MenuButtonFontSize}" />
        <Setter Property="Padding" Value="{StaticResource MenuButtonPadding}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MenuButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource MenuButtonHoverBackgroundBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 设置中心侧边栏导航项 -->
    <Style x:Key="NavRadioButton" TargetType="RadioButton">
        <Setter Property="GroupName" Value="Nav" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Foreground" Value="{StaticResource HeaderForegroundBrush}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="Indicator"
                                Width="3"
                                HorizontalAlignment="Left"
                                Background="{StaticResource AccentBrush}"
                                Opacity="0" />
                        <Border x:Name="Bd" Background="Transparent" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="White" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 设置中心扁平蓝动作按钮 -->
    <Style x:Key="ActionButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="20,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ActionButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 设置中心 DataGrid 列头（无 key：仅 SettingsWindow 有 DataGrid） -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource HeaderBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource HeaderForegroundBrush}" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
    </Style>

</ResourceDictionary>
