<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ===== 主题画刷（非 JSON 配置的颜色，集中管理） ===== -->
    <SolidColorBrush x:Key="AccentBrush"           Color="#0066CC" />
    <SolidColorBrush x:Key="AccentHoverBrush"      Color="#0055AA" />
    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#F7F7F7" />
    <SolidColorBrush x:Key="DividerBrush"           Color="#EAEAEA" />
    <SolidColorBrush x:Key="GridLinesBrush"         Color="#EFEFEF" />
    <SolidColorBrush x:Key="AlternatingRowBrush"    Color="#FAFAFA" />
    <SolidColorBrush x:Key="HeaderBackgroundBrush"  Color="#F7F7F7" />
    <SolidColorBrush x:Key="HeaderForegroundBrush"  Color="#333333" />
    <SolidColorBrush x:Key="NavHoverBrush"          Color="#EBEBEB" />
    <SolidColorBrush x:Key="NavSelectedBrush"       Color="#E8F1FB" />
    <SolidColorBrush x:Key="SecondaryTextBrush"     Color="#888888" />
    <SolidColorBrush x:Key="FieldTitleBrush"        Color="#202020" />
    <SolidColorBrush x:Key="ControlBgBrush"         Color="#F8F8F8" />
    <SolidColorBrush x:Key="ControlBorderBrush"     Color="#E0E0E0" />
    <SolidColorBrush x:Key="RowHoverBrush"          Color="#F5F9FF" />

    <!-- ===== 尺寸 / 间距 / 圆角（纯布局，非 JSON） ===== -->
    <Thickness    x:Key="MenuPadding">12</Thickness>
    <Thickness    x:Key="MenuButtonPadding">14,8</Thickness>
    <Thickness    x:Key="ActionButtonMargin">0,4</Thickness>
    <CornerRadius x:Key="MenuButtonCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ActionButtonCornerRadius">6</CornerRadius>
    <sys:Double   x:Key="MenuButtonFontSize">15</sys:Double>
    <sys:Double   x:Key="ActionButtonMinWidth">180</sys:Double>
    <sys:Double   x:Key="SettingsButtonSize">30</sys:Double>
    <GridLength   x:Key="SidebarWidth">160</GridLength>

    <!-- ===== 公共样式 ===== -->

    <!-- 唤醒菜单动作按钮。背景色走 DynamicResource，由 MainWindow code-behind 从 JSON 注入 -->
    <Style x:Key="MenuButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource MenuButtonBackgroundBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="{StaticResource MenuButtonFontSize}" />
        <Setter Property="Padding" Value="{StaticResource MenuButtonPadding}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource MenuButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource MenuButtonHoverBackgroundBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 设置中心侧边栏导航项（Fluent：选中浅蓝底 + Accent 指示条与文字；hover 丝滑淡入） -->
    <Style x:Key="NavRadioButton" TargetType="RadioButton">
        <Setter Property="GroupName" Value="Nav" />
        <Setter Property="Height" Value="40" />
        <Setter Property="Foreground" Value="#555555" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Border x:Name="HoverBg" Background="{StaticResource NavHoverBrush}"
                                CornerRadius="4" Margin="6,2" Opacity="0" />
                        <Border x:Name="Indicator" Width="3" Height="16"
                                HorizontalAlignment="Left" Margin="6,0,0,0"
                                Background="{StaticResource AccentBrush}" CornerRadius="2" Opacity="0" />
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Margin="6,2">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="16,0,0,0" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavSelectedBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                            <Setter TargetName="HoverBg" Property="Opacity" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 设置中心扁平蓝动作按钮 -->
    <Style x:Key="ActionButton" TargetType="Button">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{StaticResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Padding" Value="20,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ActionButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== DataGrid 扁平化（仅 SettingsWindow 动作管理使用） ===== -->

    <!-- 列头：透明底 + 仅下边框 + SemiBold，无竖向分隔 -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Height" Value="40" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="SeparatorVisibility" Value="Collapsed" />
    </Style>

    <!-- 行：透明底，hover 浅蓝、选中 NavSelectedBrush；去掉默认选择高亮覆盖 -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Border x:Name="RowBd" Background="{TemplateBinding Background}">
                        <DataGridCellsPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBd" Property="Background" Value="{StaticResource RowHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBd" Property="Background" Value="{StaticResource NavSelectedBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 单元格：去焦点虚线框与默认选择底色，统一内边距，垂直居中 -->
    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===== 设置页表单排版 ===== -->

    <Style x:Key="FieldTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
    </Style>

    <Style x:Key="FieldDesc" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <!-- 分区小标题：合并页内分组（如「截屏」「贴图」），字号介于页面标题(22)与字段标题(13)之间 -->
    <Style x:Key="SectionHeader" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="Margin" Value="0,0,0,10" />
    </Style>

    <!-- 扁平 TextBox：去 3D 边框、圆角、聚焦变 Accent -->
    <Style x:Key="FlatTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource ControlBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="Center" Focusable="False" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="White" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 精致色块：圆角 + 描边，像调色板按钮 -->
    <Style x:Key="ColorSwatch" TargetType="Border">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Margin" Value="10,0,0,0" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <!-- 扁平 ComboBox：与 FlatTextBox 同语言，圆角 + Accent 聚焦 + 圆角下拉 -->
    <Style x:Key="FlatComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource ControlBgBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" />
                        <ToggleButton x:Name="Toggle" Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press" Background="Transparent" BorderThickness="0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" BorderThickness="0" />
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Grid IsHitTestVisible="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="10" Foreground="{StaticResource SecondaryTextBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0" />
                        </Grid>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom" AllowsTransparency="True"
                               Focusable="False" PopupAnimation="Slide">
                            <Border Background="White" BorderBrush="{StaticResource ControlBorderBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="4" Margin="0,4,0,0">
                                <ScrollViewer MaxHeight="240">
                                    <ItemsPresenter />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            <Setter TargetName="Bd" Property="Background" Value="White" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem（全局）：扁平 hover/选中，圆角浅蓝 -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavSelectedBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavSelectedBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== PinWindow 批注工具栏 ===== -->

    <!-- 扁平图标按钮（RadioButton）：批注工具栏 指针/画框/文字 切换。
         透明底，选中 Accent 底 + 白字，hover 浅底。Content 为 Segoe MDL2 Assets 字形。 -->
    <Style x:Key="FlatIconButton" TargetType="RadioButton">
        <Setter Property="GroupName" Value="AnnotationTool" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="28" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
        <Setter Property="Foreground" Value="{StaticResource FieldTitleBrush}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource AccentBrush}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 圆形色块按钮（RadioButton）：批注颜色预设。实际颜色由实例 Foreground 指定，
         选中时 Accent 描边环显现。 -->
    <Style x:Key="FlatColorSwatch" TargetType="RadioButton">
        <Setter Property="GroupName" Value="AnnotationColor" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Ellipse x:Name="Swatch" Width="16" Height="16"
                                 Fill="{TemplateBinding Foreground}"
                                 Stroke="{StaticResource ControlBorderBrush}" StrokeThickness="1"
                                 HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="Ring" Width="20" Height="20"
                                 Stroke="{StaticResource AccentBrush}" StrokeThickness="1.5"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Opacity="0" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Ring" Property="Opacity" Value="0.5" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Ring" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
