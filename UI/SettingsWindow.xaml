<Window x:Class="MyQuicker.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="750"
        Height="500"
        ResizeMode="NoResize"
        Background="White"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource SidebarWidth}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBackgroundBrush}"
                BorderThickness="0,0,1,0"
                BorderBrush="{StaticResource DividerBrush}">
            <StackPanel>
                <TextBlock Text="⚙ 设置中心" FontSize="18" FontWeight="Bold"
                           Margin="20,20,0,30" Foreground="{StaticResource HeaderForegroundBrush}" />
                <RadioButton x:Name="NavGeneral" Content="常规"
                             Style="{StaticResource NavRadioButton}" IsChecked="True" />
                <RadioButton x:Name="NavActions" Content="动作管理"
                             Style="{StaticResource NavRadioButton}" />
                <RadioButton x:Name="NavSnipping" Content="截屏与贴图"
                             Style="{StaticResource NavRadioButton}" />
                <RadioButton x:Name="NavMenu" Content="菜单"
                             Style="{StaticResource NavRadioButton}" />
            </StackPanel>
        </Border>

        <!-- Content -->
        <Border Grid.Column="1" Background="#FAFAFA">
            <Grid Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Page 1: General -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsChecked, ElementName=NavGeneral, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="常规设置" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource FieldTitleBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="配置唤醒菜单的触发方式。"
                                   FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,20" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="280" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="唤醒键" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="按下此键弹出唤醒菜单" />
                            </StackPanel>
                            <ComboBox x:Name="WakeupKeyCombo" Grid.Column="1"
                                      Style="{StaticResource FlatComboBox}"
                                      Width="280" HorizontalAlignment="Right" SelectedIndex="0">
                                <ComboBoxItem Content="鼠标中键" />
                                <ComboBoxItem Content="侧键后退 (XButton1)" />
                                <ComboBoxItem Content="单纯画圈 (无按键)" />
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="280" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="唤醒时拦截按键" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="不把唤醒键传递给当前应用" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="InterceptWakeupCheckBox"
                                      VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="280" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="画圈灵敏度" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="仅画圈模式生效" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" x:Name="CircleSensitivityCombo"
                                      Style="{StaticResource FlatComboBox}"
                                      Width="280" HorizontalAlignment="Right" SelectedIndex="1">
                                <ComboBoxItem Content="低（不易误触）" />
                                <ComboBoxItem Content="中（默认）" />
                                <ComboBoxItem Content="高（易触发）" />
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Page 2: Actions -->
                <Grid Grid.Row="0"
                      Visibility="{Binding IsChecked, ElementName=NavActions, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Margin="0,0,8,12">
                        <TextBlock Text="动作管理" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource FieldTitleBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="双击单元格编辑；末行可新增，选中行按 Delete 删除。"
                                   FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>
                    <DataGrid x:Name="ActionsGrid" Grid.Row="1"
                              AutoGenerateColumns="False"
                              CanUserAddRows="True"
                              CanUserDeleteRows="True"
                              CanUserResizeColumns="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{StaticResource GridLinesBrush}"
                              BorderThickness="0"
                              Background="Transparent"
                              RowBackground="Transparent"
                              AlternatingRowBackground="Transparent"
                              AlternationCount="0"
                              ColumnHeaderHeight="40"
                              RowHeight="38">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="图标" Width="56">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   Text="{Binding Icon, Converter={StaticResource HexToGlyphConverter}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource FlatTextBox}"
                                                 HorizontalContentAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"
                                                EditingElementStyle="{StaticResource FlatTextBox}" />
                            <DataGridTextColumn Header="命令" Binding="{Binding CommandId}" Width="2*"
                                                EditingElementStyle="{StaticResource FlatTextBox}" />
                            <DataGridTextColumn Header="参数" Binding="{Binding Arguments}" Width="2*"
                                                EditingElementStyle="{StaticResource FlatTextBox}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Page 3: Snipping & Pin -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsChecked, ElementName=NavSnipping, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="截屏与贴图" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource FieldTitleBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="智能寻边选区与贴图窗口的视觉参数。"
                                   FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,18" />

                        <TextBlock Text="截屏" Style="{StaticResource SectionHeader}" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="红框颜色" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="寻边时高亮目标窗口的描边色" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="SnippingBorderColorBox" Style="{StaticResource FlatTextBox}" Width="158" />
                                <Border x:Name="SnippingBorderColorPreview" Style="{StaticResource ColorSwatch}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="暗罩浓度" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="0~1，越大越暗" />
                            </StackPanel>
                            <TextBox Grid.Column="1" x:Name="SnippingMaskAlphaBox"
                                     Style="{StaticResource FlatTextBox}" Width="200" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="点击/拖拽阈值" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="位移超过此值即升级为拖拽（DIP）" />
                            </StackPanel>
                            <TextBox Grid.Column="1" x:Name="SnippingDragThresholdBox"
                                     Style="{StaticResource FlatTextBox}" Width="200" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="截图后" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="结算时的动作" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" x:Name="AfterScreenshotCombo"
                                      Style="{StaticResource FlatComboBox}"
                                      Width="200" HorizontalAlignment="Right" SelectedIndex="0">
                                <ComboBoxItem Content="钉为贴图并复制" />
                                <ComboBoxItem Content="仅复制到剪贴板" />
                                <ComboBoxItem Content="仅钉为贴图" />
                            </ComboBox>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="截图范围" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="多屏时截哪些显示器" />
                            </StackPanel>
                            <ComboBox Grid.Column="1" x:Name="CaptureScopeCombo"
                                      Style="{StaticResource FlatComboBox}"
                                      Width="200" HorizontalAlignment="Right" SelectedIndex="0">
                                <ComboBoxItem Content="所有显示器" />
                                <ComboBoxItem Content="当前光标所在显示器" />
                            </ComboBox>
                        </Grid>

                        <!-- 贴图分组 -->
                        <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,18,0,14" />
                        <TextBlock Text="贴图" Style="{StaticResource SectionHeader}" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="边界颜色" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="“显示边界”开启时的描边色" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="PinBorderColorBox" Style="{StaticResource FlatTextBox}" Width="158" />
                                <Border x:Name="PinBorderColorPreview" Style="{StaticResource ColorSwatch}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="默认不透明度" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="0~1 之间的数值" />
                            </StackPanel>
                            <TextBox Grid.Column="1" x:Name="PinDefaultOpacityBox"
                                     Style="{StaticResource FlatTextBox}" Width="200" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="默认显示边界" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="钉图时默认开启边框" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="PinDefaultShowBorderBox"
                                      VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="默认批注模式" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="钉图时默认开启批注（Hover 工具栏）" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="PinDefaultAnnotationModeBox"
                                      VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="默认置顶" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="钉图时默认置顶在前" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="PinDefaultTopmostBox"
                                      VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="默认显示阴影" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="钉图时默认开启投影" />
                            </StackPanel>
                            <CheckBox Grid.Column="1" x:Name="PinDefaultShowShadowBox"
                                      VerticalAlignment="Center" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Page 4: Menu -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding IsChecked, ElementName=NavMenu, Converter={StaticResource BoolToVis}}">
                    <StackPanel Margin="0,0,8,0">
                        <TextBlock Text="菜单" FontSize="22" FontWeight="SemiBold"
                                   Foreground="{StaticResource FieldTitleBrush}" Margin="0,0,0,4" />
                        <TextBlock Text="唤醒菜单的尺寸与配色，应用后即时刷新。"
                                   FontSize="13" Foreground="{StaticResource SecondaryTextBrush}" Margin="0,0,0,18" />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="面板宽度" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="内容区宽度，单位 DIP" />
                            </StackPanel>
                            <TextBox Grid.Column="1" x:Name="MenuWidthBox"
                                     Style="{StaticResource FlatTextBox}" Width="200" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="面板高度" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="内容区高度，单位 DIP" />
                            </StackPanel>
                            <TextBox Grid.Column="1" x:Name="MenuHeightBox"
                                     Style="{StaticResource FlatTextBox}" Width="200" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="圆角半径" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="单位 px" />
                            </StackPanel>
                            <TextBox Grid.Column="1" x:Name="MenuCornerRadiusBox"
                                     Style="{StaticResource FlatTextBox}" Width="200" HorizontalAlignment="Right" />
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="外层背景色" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="菜单半透明底色（#AARRGGBB）" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="MenuBackgroundBox" Style="{StaticResource FlatTextBox}" Width="158" />
                                <Border x:Name="MenuBackgroundPreview" Style="{StaticResource ColorSwatch}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="按钮背景色" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="动作按钮常态底色" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="MenuButtonBgBox" Style="{StaticResource FlatTextBox}" Width="158" />
                                <Border x:Name="MenuButtonBgPreview" Style="{StaticResource ColorSwatch}" />
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="200" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource FieldTitle}" Text="按钮悬停色" />
                                <TextBlock Style="{StaticResource FieldDesc}" Text="鼠标悬停时的底色" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBox x:Name="MenuButtonHoverBgBox" Style="{StaticResource FlatTextBox}" Width="158" />
                                <Border x:Name="MenuButtonHoverBgPreview" Style="{StaticResource ColorSwatch}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Apply button -->
                <Button Grid.Row="1" Content="应用设置" Style="{StaticResource ActionButton}"
                        Click="SaveButton_Click" HorizontalAlignment="Right" Margin="0,12,0,0" />
            </Grid>
        </Border>
    </Grid>
</Window>
