<Window x:Class="MyQuicker.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MyQuicker.UI"
        xmlns:models="clr-namespace:MyQuicker.Models"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <!-- Width/Height/Background/CornerRadius 由 code-behind 从 SettingsModel.Menu 注入；
         按钮样式 MenuButtonStyle 与公共尺寸来自 Resources/ThemeStyles.xaml。 -->
    <Border x:Name="RootBorder"
            Padding="{StaticResource MenuPadding}">
        <Grid>
            <ItemsControl x:Name="ActionsControl"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:ActionItem}">
                        <Button Content="{Binding Name}"
                                Click="ActionButton_Click"
                                Style="{StaticResource MenuButtonStyle}"
                                Margin="{StaticResource ActionButtonMargin}"
                                MinWidth="{StaticResource ActionButtonMinWidth}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button x:Name="SettingsButton"
                    Click="SettingsButton_Click"
                    Style="{StaticResource MenuButtonStyle}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Width="{StaticResource SettingsButtonSize}"
                    Height="{StaticResource SettingsButtonSize}"
                    Padding="0"
                    ToolTip="设置">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="14" />
            </Button>
        </Grid>
    </Border>
</Window>
