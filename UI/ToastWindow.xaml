<Window x:Class="MyQuicker.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toast"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        SizeToContent="WidthAndHeight"
        Opacity="0">
    <!-- 轻量瞬时通知：暗色半透明圆角卡片，白字，不抢焦点，定时淡出。Per docs/03 §8。 -->
    <Border Background="#E6323232" CornerRadius="8" Padding="16,10" MaxWidth="360">
        <TextBlock x:Name="MessageText" Foreground="White" FontSize="13" TextWrapping="Wrap" />
    </Border>
</Window>
